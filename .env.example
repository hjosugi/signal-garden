# Web server
ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080

# Protect the private reading index. Leave empty only for local development.
INBOX_TOKEN=change-this-private-token

# Required for POST /api/refresh. Keep it different from INBOX_TOKEN.
ADMIN_TOKEN=change-this-admin-token

# Collection
INITIAL_REFRESH=true
REFRESH_INTERVAL=30m
REQUEST_TIMEOUT=15s
FEED_WORKERS=6
MAX_ITEMS=5000
SITE_CONFIG=config/site.json
FEEDS_CONFIG=config/feeds.json
DATA_PATH=data/items.json

# Local AI is optional. Lexical BM25 search works without Ollama.
OLLAMA_BASE_URL=http://localhost:11434/api
ENABLE_EMBEDDINGS=false
OLLAMA_EMBED_MODEL=embeddinggemma
ENABLE_LLM_SUMMARY=false
OLLAMA_CHAT_MODEL=
SUMMARY_LANGUAGE=ja

# Structured logs are useful in containers.
LOG_JSON=false
